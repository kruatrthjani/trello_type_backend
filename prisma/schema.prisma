generator client {
  provider     = "prisma-client-js"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  password         String?
  name             String?
  createdAt        DateTime      @default(now())
  provider         String?
  providerId       String?
  role             roleType      @default(DEVELOPER)
  boardMemberships BoardMember[]
  clientProjects   Projects[]    @relation("ClientProjects")
  managedProjects  Projects[]    @relation("ManagedProjects")

  @@unique([provider, providerId])
}

model Projects {
  projectId         String      @id @default(uuid())
  projectName       String
  category          String?
  projectOrigin     String
  createdAt         DateTime    @default(now())
  estimatedDuration String
  projectType       ProjectType
  clientId          String?
  projectManagerId  String?
  boards            Boards[]
  client            User?       @relation("ClientProjects", fields: [clientId], references: [id])
  manager           User?       @relation("ManagedProjects", fields: [projectManagerId], references: [id])

  @@unique([projectName, clientId])
}

model Boards {
  boardId          String        @id @default(uuid())
  boardName        String
  boardDescription String?
  projectId        String
  createdAt        DateTime      @default(now())
  members          BoardMember[]
  project          Projects      @relation(fields: [projectId], references: [projectId], onDelete: Cascade)

  @@unique([boardName, projectId])
}

model BoardMember {
  id        String   @id @default(uuid())
  userId    String
  boardId   String
  createdAt DateTime @default(now())
  board     Boards   @relation(fields: [boardId], references: [boardId], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, boardId])
}

model Card {
  cardId          String     @id @default(uuid())
  cardTitle       String
  cardDescription String
  status          StatusType
}

enum roleType {
  DEVELOPER
  CLIENT
  MANAGER
}

enum ProjectType {
  client
  inhouse
}

enum BoardRole {
  ADMIN
  MEMBER
  VIEWER
  CLIENT
}

enum StatusType {
  PENDING
  INPROGRESS
  DONE
}
