generator client {
  provider     = "prisma-client-js"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String?
  name       String?
  createdAt  DateTime @default(now())

  // Auth (optional)
  provider   String?
  providerId String?

  // Relations
  clientProjects   Projects[] @relation("ClientProjects")
  managedProjects  Projects[] @relation("ManagedProjects")
  boardMemberships BoardMember[]

  @@unique([provider, providerId])
}

model Projects {
  projectId         String      @id @default(uuid())
  projectName       String
  category          String?
  projectOrigin     String
  createdAt         DateTime    @default(now())
  estimatedDuration String
  projectType       ProjectType

  // ✅ RELATIONS ONLY (removed old fields)
  clientId          String?
  client            User? @relation("ClientProjects", fields: [clientId], references: [id], onDelete: SetNull)

  projectManagerId  String?
  manager           User? @relation("ManagedProjects", fields: [projectManagerId], references: [id], onDelete: SetNull)

  boards            Boards[]

  // ✅ Optional uniqueness (better than old one)
  @@unique([projectName, clientId])
}

model Boards {
  boardId          String  @id @default(uuid())
  boardName        String
  boardDescription String?
  createdAt        DateTime @default(now())

  // ✅ RELATION ONLY (removed old assigner)
  projectId        String
  project          Projects @relation(fields: [projectId], references: [projectId], onDelete: Cascade)

  members          BoardMember[]

  // Prevent duplicate board names in same project
  @@unique([boardName, projectId])
}

model BoardMember {
  id       String @id @default(uuid())

  userId   String
  boardId  String
  role     BoardRole
  createdAt DateTime @default(now())

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  board    Boards @relation(fields: [boardId], references: [boardId], onDelete: Cascade)

  @@unique([userId, boardId])
}

enum ProjectType {
  client
  inhouse
}

enum BoardRole {
  ADMIN
  MEMBER
  VIEWER
}